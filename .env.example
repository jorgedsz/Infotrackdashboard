# Credenciales de GoHighLevel (LeadConnector API v2)
# Copia este archivo a .env y rellena los valores.

# Token de acceso. Recomendado: "Private Integration" token desde
# GHL > Settings > Private Integrations (empieza por "pit-...").
GHL_TOKEN=

# ID de la location (sub-cuenta) en GHL.
GHL_LOCATION_ID=

# (Opcional) ID del pipeline a usar. Si se deja vacío, trae todas las oportunidades.
# Descúbrelo en GET /api/ghl/pipelines
GHL_PIPELINE_ID=

# Puerto del backend y cada cuánto refresca desde GHL (ms).
PORT=3001
REFRESH_MS=30000

# --- Autenticación (base de datos) ---
# Si DATABASE_URL está presente, se activa el login y se protegen los datos.
# En Railway, agrega un Postgres y usa su DATABASE_URL.
DATABASE_URL=
# Secreto para firmar los tokens de sesión (cualquier cadena larga y aleatoria).
JWT_SECRET=
# Admin inicial (se crea automáticamente al arrancar si no existe).
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
